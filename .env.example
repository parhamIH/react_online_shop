# =============================================================================
# React Shop — Environment Variables
# Copy to .env:  cp .env.example .env
# =============================================================================

# --- Database (PostgreSQL in Docker) ---
POSTGRES_DB=react_shop
POSTGRES_USER=react_shop
POSTGRES_PASSWORD=react_shop_secret
POSTGRES_PORT=5432

# --- Django Backend ---
SECRET_KEY=change-this-to-a-random-secret-key-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend,nginx,0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost,http://127.0.0.1

# ZarinPal payment gateway
ZARINPAL_MERCHANT_ID=
ZARINPAL_SANDBOX=True

# --- Frontend (Vite) ---
VITE_API_BASE_URL=/api
VITE_USE_API=true
VITE_BASE_PATH=/

# --- Docker Ports ---
HTTP_PORT=80
BACKEND_PORT=8000
FRONTEND_PORT=5173
